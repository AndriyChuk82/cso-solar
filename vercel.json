{
  "redirects": [
    { "source": "/", "destination": "/proposals/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/warehouse", "destination": "/warehouse/index.html" },
    { "source": "/warehouse/assets/(.*)", "destination": "/warehouse/assets/$1" },
    { "source": "/warehouse/(.*)", "destination": "/warehouse/index.html" },
    { "source": "/projects", "destination": "/projects/index.html" },
    { "source": "/projects/assets/(.*)", "destination": "/projects/assets/$1" },
    { "source": "/projects/(.*)", "destination": "/projects/index.html" },
    { "source": "/proposals", "destination": "/proposals/index.html" },
    { "source": "/proposals/assets/(.*)", "destination": "/proposals/assets/$1" },
    { "source": "/proposals/(.*)", "destination": "/proposals/index.html" },
    { "source": "/green-tariff", "destination": "/green-tariff/index.html" },
    { "source": "/green-tariff/assets/(.*)", "destination": "/green-tariff/assets/$1" },
    { "source": "/green-tariff/(.*)", "destination": "/green-tariff/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
