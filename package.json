{
  "name": "cso-solar-monorepo",
  "version": "1.0.0",
  "description": "CSO Solar — Unified Monorepo with Design System",
  "private": true,
  "workspaces": [
    "packages/*",
    "warehouse",
    "projects",
    "proposals",
    "green-tariff",
    "dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:dashboard": "npm run dev --workspace=dashboard",
    "dev:warehouse": "npm run dev --workspace=warehouse",
    "dev:proposals": "npm run dev --workspace=proposals",
    "dev:projects": "npm run dev --workspace=projects",
    "dev:green-tariff": "npm run dev --workspace=green-tariff",
    "dev:all": "concurrently \"npm run dev:dashboard\" \"npm run dev:warehouse\" \"npm run dev:proposals\" \"npm run dev:projects\"",
    "hash-password": "node scripts/hash-password.js",
    "install:all": "npm install",
    "clean": "rm -rf node_modules packages/*/node_modules warehouse/node_modules projects/node_modules proposals/node_modules green-tariff/node_modules"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "bcryptjs": "^2.4.3",
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  }
}
