/**
 * Обробка GET запитів
 */
function doGet(e) {
  return ContentService.createTextOutput(
    JSON.stringify({ status: 'ok', message: 'CSO Solar Proposals API v1.0' })
  ).setMimeType(ContentService.MimeType.JSON);
}

/**
 * Обробка POST запитів
 */
function doPost(e) {
  try {
    const data = JSON.parse(e.postData.contents);
    const action = data.action;

    if (action === 'getAllProducts') {
      return sendJson(getAllProducts());
    }

    if (action === 'getSheet') {
      return sendJson(getSheetData(data.sheetName, data.spreadsheetId));
    }

    if (action === 'getCustomMaterials') {
      return sendJson(getCustomMaterials());
    }

    if (action === 'updateMaterialPrice') {
      return sendJson(updateMaterialPrice(data.id, data.priceUsd, data.priceUah));
    }

    if (action === 'getProposals') {
      return sendJson(getProposals());
    }

    if (action === 'saveProposal') {
      return sendJson(saveProposal(data.proposal));
    }

    if (action === 'getRates') {
      return sendJson(getRates());
    }

    if (action === 'addCustomMaterial') {
      return sendJson(addCustomMaterial(data.product));
    }

    if (action === 'deleteCustomMaterial') {
      return sendJson(deleteCustomMaterial(data.productId));
    }

    if (action === 'getAllData') {
      return sendJson(getAllData());
    }

    // === PROJECTS MODULE ACTIONS ===
    if (action === 'getProjects') {
      return sendJson(getProjects(data.userEmail));
    }

    if (action === 'saveProject') {
      return sendJson(saveProject(data.project));
    }

    if (action === 'getProjectDetails') {
      return sendJson(getProjectDetails(data.projectId));
    }

    if (action === 'savePayment') {
      return sendJson(savePayment(data.payment));
    }

    if (action === 'cancelPayment') {
      return sendJson(cancelPayment(data.paymentId));
    }

    if (action === 'saveProjectItem') {
      return sendJson(saveProjectItem(data.item));
    }

    if (action === 'deleteProjectItem') {
      return sendJson(deleteProjectItem(data.itemId));
    }

    if (action === 'syncProjectItems') {
      return sendJson(syncProjectItems(data.projectId));
    }

    return sendJson({ success: false, error: 'Unknown action: ' + action });
  } catch (err) {
    return sendJson({ success: false, error: err.toString() });
  }
}

/**
 * Завантажує всі продукти з усіх категорій (зовнішня база)
 */
function getAllProducts() {
  try {
    const allProducts = [];

    CONFIG.SHEETS.forEach(sheet => {
      // Пропускаємо ДОВІДНИК_ТОВАРІВ тут, бо він завантажується окремою функцією getCustomMaterials
      if (sheet.name === 'ДОВІДНИК_ТОВАРІВ' || sheet.mainCat === 'Власний матеріал' || sheet.mainCat === 'Власні матеріали') {
        return;
      }

      // ТОВАРИ З КАТАЛОГУ ЗНАХОДЯТЬСЯ У MATERIALS_SPREADSHEET_ID
      const spreadsheetId = sheet.spreadsheetId || CONFIG.MATERIALS_SPREADSHEET_ID;
      const sheetData = getSheetData(sheet.name, spreadsheetId, sheet.gid);

      if (sheetData.success && sheetData.data) {
        sheetData.data.forEach((row, index) => {
          // Пропускаємо порожні рядки або рядки без назви
          if (!row[0] || row[0].toString().trim() === "" || row[0] === "Модель") return;

          allProducts.push({
            id: generateId(row[0], sheet.name),
            name: row[0] || '',
            price: parsePrice(row[1]),
            currency: parseCurrency(row[1]),
            unit: row[2] || 'шт',
            description: row[3] || '',
            manufacturer: row[4] || '',
            power: row[5] || '',
            warranty: row[6] || '',
            category: sheet.name,
            mainCategory: sheet.mainCat,
            inStock: true
          });
        });
      }
    });

    return { success: true, products: allProducts };
  } catch (err) {
    return { success: false, error: 'getAllProducts error: ' + err.toString() };
  }
}

/**
 * Завантажує дані з конкретного аркуша
 * Якщо доступ закрито, використовуємо обхідний шлях (CSV fetch), як і просив користувач
 */
function getSheetData(sheetName, spreadsheetId, gid) {
  try {
    spreadsheetId = spreadsheetId || CONFIG.SPREADSHEET_ID;
    let data;

    try {
      // Спочатку пробуємо стандартний метод (якщо є доступ)
      const ss = SpreadsheetApp.openById(spreadsheetId);
      const sheet = ss.getSheetByName(sheetName);
      if (sheet) {
        data = sheet.getDataRange().getValues();
      } else {
        throw new Error('Sheet not found by name');
      }
    } catch (e) {
      // Якщо таблиця закрита для доступу через API (але опублікована в Web),
      // завантажуємо її як CSV!
      if (!gid && gid !== 0) {
         return { success: false, error: 'GID is required for CSV fallback' };
      }
      const csvUrl = 'https://docs.google.com/spreadsheets/d/' + spreadsheetId + '/export?format=csv&gid=' + gid;
      const response = UrlFetchApp.fetch(csvUrl, { muteHttpExceptions: true });
      if (response.getResponseCode() !== 200) {
         return { success: false, error: 'Cannot fetch CSV. Access might be fully restricted.' };
      }
      const csvText = response.getContentText();
      data = Utilities.parseCsv(csvText);
    }

    if (!data || data.length < 2) {
      return { success: false, error: 'No data or empty sheet' };
    }

    // Пропускаємо заголовок (перший рядок) і порожні рядки
    const rows = data.slice(1).filter(row => row[0] && row[1]);

    return { success: true, data: rows };
  } catch (err) {
    return { success: false, error: err.toString() };
  }
}

/**
 * Парсить ціну з рядка
 */
function parsePrice(str) {
  if (!str) return 0;
  const cleaned = str.toString().replace(/\s+/g, '').replace(/,/g, '.');
  const match = cleaned.match(/[\d.]+/);
  return match ? parseFloat(match[0]) : 0;
}

/**
 * Визначає валюту з рядка
 */
function parseCurrency(str) {
  if (!str) return 'USD';
  const s = str.toString().toUpperCase();
  if (s.includes('€') || s.includes('EUR')) return 'EUR';
  if (s.includes('₴') || s.includes('UAH') || s.includes('ГРН')) return 'UAH';
  return 'USD';
}

/**
 * Генерує стабільний ID для продукту
 */
function generateId(name, category) {
  const str = (name + category).toLowerCase();
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    const char = str.charCodeAt(i);
    hash = ((hash << 5) - hash) + char;
    hash = hash & hash;
  }
  return 'prod_' + Math.abs(hash).toString(36);
}

/**
 * Відправляє JSON відповідь
 */
