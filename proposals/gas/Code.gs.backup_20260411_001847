// ============================================================================
const PROJECT_HEADERS = [
  'id', 'name', 'client_name', 'client_phone', 'address',
  'proposal_id', 'proposal_number', 'total_cost', 'agreed_sum',
  'total_paid', 'balance', 'status', 'notes',
  'created_at', 'closed_date', 'user_email'
];

const PAYMENT_HEADERS = ['id', 'project_id', 'date', 'sum', 'payment_type', 'note', 'status', 'created_at'];
const ITEM_HEADERS = ['id', 'project_id', 'name', 'quantity', 'price', 'sum', 'note'];

/**
 * Отримує список проєктів для користувача
 */
function getProjects(userEmail) {
  try {
    const ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
    let sheet = ss.getSheetByName('projects');

    if (!sheet) {
      return { success: true, projects: [] };
    }

    const data = sheet.getDataRange().getValues();
    if (data.length < 2) return { success: true, projects: [] };

    const paymentsSheet = ss.getSheetByName('project_payments');
    const paymentMap = {};
    if (paymentsSheet) {
      const pData = paymentsSheet.getDataRange().getValues();
      if (pData.length > 1) {
        for (let j = 1; j < pData.length; j++) {
          const pid = String(pData[j][1]);
          const sum = parseFloat(pData[j][3]) || 0;
          const status = String(pData[j][6] || '').toLowerCase();
          if (!status.includes('скасовано')) {
            paymentMap[pid] = (paymentMap[pid] || 0) + sum;
          }
        }
      }
    }

    const projects = [];

    for (let i = 1; i < data.length; i++) {
      const row = data[i];
      const project = {};

      PROJECT_HEADERS.forEach((header, idx) => {
        project[header] = row[idx];
      });

      // Динамічний перерахунок оплат
      const pid = String(project.id);
      const computedPaid = paymentMap[pid] || 0;
      project.total_paid = computedPaid;
      
      const cost = parseFloat(project.agreed_sum) || parseFloat(project.total_cost) || 0;
      project.balance = cost - computedPaid;

      projects.push(project);
    }

    return { success: true, projects: projects };
  } catch (err) {
    return { success: false, error: err.toString() };
  }
}

/**
 * Зберігає або оновлює проєкт
 */
function saveProject(project) {
  try {
    const ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
    const sheetName = 'projects';

    let sheet = ss.getSheetByName(sheetName);

    if (!sheet) {
      sheet = ss.insertSheet(sheetName);
      sheet.appendRow(PROJECT_HEADERS);
    }

    const data = sheet.getDataRange().getValues();
    let rowIndex = -1;
    const projectId = project.id || Utilities.getUuid();

    // Шукаємо існуючий проєкт
    for (let i = 1; i < data.length; i++) {
      if (String(data[i][0]) === String(projectId)) {
        rowIndex = i + 1;
        break;
      }
    }

    // Формуємо рядок
    const rowData = [
      projectId,
      project.name || '',
      project.client_name || '',
      project.client_phone || '',
      project.address || '',
      project.proposal_id || '',
      project.proposal_number || '',
      Number(project.total_cost || 0),
      Number(project.agreed_sum || 0),
      Number(project.total_paid || 0),
      Number(project.balance || 0),
      project.status || 'В роботі',
      project.notes || '',
      project.created_at || new Date().toISOString(),
      project.closed_date || '',
      project.user_email || ''
    ];

    if (rowIndex > 0) {
      sheet.getRange(rowIndex, 1, 1, rowData.length).setValues([rowData]);
    } else {
      sheet.appendRow(rowData);
    }

    // Якщо є items_from_cp, копіюємо їх у project_items
    if (project.items_from_cp && Array.isArray(project.items_from_cp)) {
      project.items_from_cp.forEach(function(item) {
        saveProjectItem({
          project_id: projectId,
          name: item.name || item.productName,
          quantity: item.quantity || 1,
          price: item.price || 0,
          sum: item.sum || (item.quantity * item.price),
          note: item.note || ''
        });
      });
    }

    SpreadsheetApp.flush();

    return {
      success: true,
      id: projectId,
      updatedProject: project
    };
  } catch (err) {
    return { success: false, error: err.toString() };
  }
}

/**
 * Отримує деталі проєкту з платежами та матеріалами
 */
function getProjectDetails(projectId) {
  try {
    const ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);

    // Проєкт
    const projectSheet = ss.getSheetByName('projects');
    if (!projectSheet) {
      return { success: false, error: 'Projects sheet not found' };
    }

    const projectData = projectSheet.getDataRange().getValues();
    let project = null;

    for (let i = 1; i < projectData.length; i++) {
      if (String(projectData[i][0]) === String(projectId)) {
        project = {};
        PROJECT_HEADERS.forEach(function(header, idx) {
          project[header] = projectData[i][idx];
        });
        break;
      }
    }

    if (!project) {
      return { success: false, error: 'Project not found' };
    }

    // Платежі
    const payments = [];
    const paymentSheet = ss.getSheetByName('project_payments');
    if (paymentSheet) {
      const paymentData = paymentSheet.getDataRange().getValues();

      for (let i = 1; i < paymentData.length; i++) {
        if (String(paymentData[i][1]) === String(projectId)) {
          const payment = {};
          PAYMENT_HEADERS.forEach(function(header, idx) {
            payment[header] = paymentData[i][idx];
          });
          payments.push(payment);
        }
      }
    }

    // Матеріали
    const items = [];
    const itemSheet = ss.getSheetByName('project_items');
    if (itemSheet) {
      const itemData = itemSheet.getDataRange().getValues();

      for (let i = 1; i < itemData.length; i++) {
        if (String(itemData[i][1]) === String(projectId)) {
          const item = {};
          ITEM_HEADERS.forEach(function(header, idx) {
            item[header] = itemData[i][idx];
          });
          items.push(item);
        }
      }
    }

    return {
      success: true,
      project: project,
      payments: payments,
      items: items
    };
  } catch (err) {
    return { success: false, error: err.toString() };
  }
}

/**
 * Зберігає платіж
 */
function savePayment(payment) {
  try {
    const ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
    const sheetName = 'project_payments';

    let sheet = ss.getSheetByName(sheetName);
    if (!sheet) {
      sheet = ss.insertSheet(sheetName);
      sheet.appendRow(PAYMENT_HEADERS);
    }

    const paymentId = payment.id || Utilities.getUuid();

    const rowData = [
      paymentId,
      payment.project_id,
      payment.date || new Date().toISOString().split('T')[0],
      Number(payment.sum || 0),
      payment.payment_type || 'Аванс',
      payment.note || '',
      payment.status || 'Активний',
      new Date().toISOString()
    ];

    // Додаємо платіж
    sheet.appendRow(rowData);
    SpreadsheetApp.flush();

    // Оновлюємо суми в таблиці projects
    try {
      const projSheet = ss.getSheetByName('projects');
      if (projSheet) {
        const projData = projSheet.getDataRange().getValues();
        let pRowIndex = -1;
        let agreedSum = 0;
        let oldPaid = 0;
        
        for (let i = 1; i < projData.length; i++) {
          if (String(projData[i][0]) === String(payment.project_id)) {
            pRowIndex = i + 1;
            const cost = Number(projData[i][7]) || 0;
            const agreed = Number(projData[i][8]) || 0;
            agreedSum = agreed > 0 ? agreed : cost;
            oldPaid = Number(projData[i][9]) || 0;
            break;
          }
        }

        if (pRowIndex > 0) {
          const newPaid = oldPaid + Number(payment.sum || 0);
          const newBalance = agreedSum - newPaid;
          const isDone = newBalance <= 0;
          
          // Column J is 10 (total_paid)
          // Column K is 11 (balance)
          projSheet.getRange(pRowIndex, 10).setValue(newPaid);
          projSheet.getRange(pRowIndex, 11).setValue(newBalance);
          if (isDone) {
            projSheet.getRange(pRowIndex, 12).setValue('Виконано'); // Status in Col L
          }
        }
      }
    } catch(err) {
      console.log('Project update failed', err);
    }

    return { success: true, id: paymentId };
  } catch (err) {
    return { success: false, error: err.toString() };
  }
}

/**
 * Скасовує платіж
 */
function cancelPayment(paymentId) {
  try {
    const ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
    const sheet = ss.getSheetByName('project_payments');

    if (!sheet) {
      return { success: false, error: 'Payments sheet not found' };
    }

    const data = sheet.getDataRange().getValues();

    for (let i = 1; i < data.length; i++) {
      if (String(data[i][0]) === String(paymentId)) {
        sheet.getRange(i + 1, 7).setValue('Скасовано');
        SpreadsheetApp.flush();

        // Оновлюємо суми в таблиці projects
        try {
          const projectId = String(data[i][1]);
          const cancelledSum = Number(data[i][3]) || 0;
          
          const projSheet = ss.getSheetByName('projects');
          if (projSheet && projectId) {
            const projData = projSheet.getDataRange().getValues();
            let pRowIndex = -1;
            let agreedSum = 0;
            let oldPaid = 0;
            let currentStatus = '';

            for (let k = 1; k < projData.length; k++) {
              if (String(projData[k][0]) === projectId) {
                pRowIndex = k + 1;
                const cost = Number(projData[k][7]) || 0;
                const agreed = Number(projData[k][8]) || 0;
                agreedSum = agreed > 0 ? agreed : cost;
                oldPaid = Number(projData[k][9]) || 0;
                currentStatus = String(projData[k][11]) || '';
                break;
              }
            }

            if (pRowIndex > 0) {
              const newPaid = oldPaid - cancelledSum;
              const newBalance = agreedSum - newPaid;
              
              projSheet.getRange(pRowIndex, 10).setValue(newPaid);
              projSheet.getRange(pRowIndex, 11).setValue(newBalance);
              
              if (currentStatus === 'Виконано' && newBalance > 0) {
                projSheet.getRange(pRowIndex, 12).setValue('В роботі');
              }
            }
          }
        } catch(e) {
          console.log('Project rollback failed', e);
        }

        return { success: true };
      }
    }

    return { success: false, error: 'Payment not found' };
  } catch (err) {
    return { success: false, error: err.toString() };
  }
}

